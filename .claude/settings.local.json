{
  "permissions": {
    "allow": [
      "Bash(gh auth:*)",
      "Bash(git update-ref:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rm:*)",
      "Bash(git restore:*)",
      "Bash(git add:*)",
      "Bash(gh pr:*)",
      "Bash(git checkout:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(gh repo:*)",
      "Bash(gh issue:*)",
      "Bash(git stash:*)",
      "Bash(git rebase:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)"
    ]
  },
  "commands": {
    "git": {
      "auto_approve": [
        "status",
        "diff",
        "log",
        "show",
        "rev-parse",
        "branch",
        "fetch",
        "pull",
        "ls-files"
      ]
    },
    "gh": {
      "auto_approve": [
        "pr status",
        "pr list",
        "pr view",
        "issue list",
        "issue view"
      ]
    }
  }
}
