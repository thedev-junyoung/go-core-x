{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git reset:*)"
    ]
  },
  "commands": {
    "git": {
      "auto_approve": [
        "status",
        "diff",
        "log",
        "show",
        "rev-parse",
        "branch",
        "fetch",
        "pull",
        "ls-files"
      ]
    },
    "gh": {
      "auto_approve": [
        "pr status",
        "pr list",
        "pr view",
        "issue list",
        "issue view"
      ]
    }
  }
}
